{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "build:win": { "outputs": ["dist/**"] },
    "build:linux": { "outputs": ["dist/**"] },
    "build:mac": { "outputs": ["dist/**"] },
    "build:release": { "outputs": ["dist/**"] },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}

{
  "name": "qq-farm-bot-nest",
  "private": true,
  "description": "QQ 农场多账号自动挂机机器人，后端基于 NestJS + SQLite（Drizzle ORM），前端基于 Vue 3 + Ant Design Vue + Pinia，提供 Web 控制面板和实时日志分析。",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "turbo run build",
    "build:core": "turbo run build -F=core",
    "build:web": "turbo run build -F=web",
    "build:link": "turbo run build -F=link",
    "dev": "turbo run dev",
    "dev:core": "turbo run dev -F=core",
    "dev:web": "turbo run dev -F=web",
    "dev:link": "turbo run dev -F=link",
    "start": "turbo run start -F=core",
    "start:link": "turbo run start -F=link",
    "lint": "turbo run lint",
    "lint:web": "turbo run lint -F=web",
    "lint:core": "turbo run lint -F=core",
    "install:all": "pnpm install -r"
  },
  "devDependencies": {
    "turbo": "^2.8.13"
  }
}
